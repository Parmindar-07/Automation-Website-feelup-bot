# =============================================================
#  .env.example — Configuration template for the CR Bot
#  Copy this file to .env and fill in your actual values.
#  Lines starting with # are comments and are ignored.
# =============================================================


# -------------------------------------------------------------
# Google Sheets — Authentication
# -------------------------------------------------------------

# Path to your Google service account JSON key file.
# (Not needed when using OAuth — see oauth_credentials.json)
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# Set to false to skip all Google Sheet read/write operations (debug mode).
GOOGLE_SHEETS_ENABLED=true


# -------------------------------------------------------------
# Google Sheets — Sheet URLs
# -------------------------------------------------------------

# Primary sheet URL (Bot 1)
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit

# Additional sheets for Bot 2 and Bot 3 (optional)
# GOOGLE_SHEET_URL_2=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_2/edit
# GOOGLE_SHEET_URL_3=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_3/edit

# Specific worksheet/tab name to use (leave blank for the first sheet/tab)
WORKSHEET_NAME=


# -------------------------------------------------------------
# Google Sheets — Column / Row Labels
# -------------------------------------------------------------

# Column A label of the row where customer IDs are written back
CUSTOMER_ID_COLUMN=customer id

# Bot processes only columns where this label has a value (comma-separated for OR logic)
REQUIRED_LABEL=Business Legal Name

# Row labels to completely ignore (comma-separated, case-insensitive)
SKIP_LABELS=

# Label of the Proceed / Decline flag row
PD_LABEL=P/D

# Default starting column letter (overridden by the popup dialog unless ASK_START_COLUMN=false)
START_COLUMN=B

# Set to false to skip the popup and use START_COLUMN directly
ASK_START_COLUMN=true


# -------------------------------------------------------------
# Website Automation
# -------------------------------------------------------------

# Target website URL
WEBSITE_URL=https://your-website.com/app

# Set to false to run in dry-run mode (no browser opened, fake customer IDs generated)
WEBSITE_ENABLED=true

# Run browser in headless mode (true = no visible window)
HEADLESS=false

# Path to store the persistent browser session (login is remembered between runs)
USER_DATA_DIR=browser_profile

# How many seconds to wait for the login page before timing out
LOGIN_WAIT_SECONDS=120

# Seconds to wait after clicking "Submit App" before clicking "DBA Info"
AFTER_START_WAIT_SECONDS=10

# Seconds to wait after form submission
AFTER_SUBMIT_WAIT_SECONDS=5

# How often (in seconds) to poll the sheet for new records
POLL_SECONDS=5


# -------------------------------------------------------------
# Website Selectors
# -------------------------------------------------------------

# Playwright selector for the "Start / Submit App" button
START_SELECTOR=text=Submit App

# Playwright selector for the "DBA Info" tab
DBA_INFO_SELECTOR=text=DBA Info

# Playwright selector for the final submit button (used as fallback reference only)
SUBMIT_SELECTOR=text=Submit Application

# Optional CSS selector to pinpoint the customer ID on the confirmation page
# Leave blank to search the full page text
CUSTOMER_ID_SELECTOR=

# Regex pattern to extract the customer ID from page text
# Group 1 must capture the numeric ID
CUSTOMER_ID_REGEX=(?:Customer\s*ID\s*#?|Cust\s*#)\s*[:#-]?\s*(\d{10})


# -------------------------------------------------------------
# Field Map
# -------------------------------------------------------------
# Maps Google Sheet row labels (left) to website form selectors (right).
# Format:   Sheet Label:selector, Another Label:selector2
#
# Selector prefixes:
#   label=<text>                  — match <input> by its <label> text
#   label=<text>|2                — second occurrence of that label
#   select-label=<text>           — match <select> by its <label> text
#   select=<css>                  — match <select> by CSS selector
#   section-select=Heading|Field  — <select> inside a named section
#   section-label=Heading|Field   — <input>  inside a named section
#   <css>                         — any raw Playwright/CSS selector
#
# Use && to fill the same value into multiple fields:
#   Business Phone:label=Location Phone #&&label=Billing Phone #
#
# Example:
# FIELD_MAP=Business Legal Name:label=Business Legal Name,Business Phone Number:label=Location Phone #
FIELD_MAP=
