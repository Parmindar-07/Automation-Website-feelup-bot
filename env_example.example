GOOGLE_SHEETS_ENABLED=true
WEBSITE_ENABLED=true

GOOGLE_SHEET_URL= #replace with google sheet tab url
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
WORKSHEET_NAME=

WEBSITE_URL= #your login page url
HEADLESS=false
USER_DATA_DIR=browser_profile
LOGIN_WAIT_SECONDS=120
AFTER_START_WAIT_SECONDS=8
AFTER_SUBMIT_WAIT_SECONDS=18

# Your sheet has labels in column A and customer records in columns B, C, D...
REQUIRED_LABEL=Business Legal Name
CUSTOMER_ID_COLUMN=Customer Id #
SKIP_LABELS=Lander Name,Representative Name,ISO Email
ASK_START_COLUMN=true
START_COLUMN=B

# Website flow selectors.
START_SELECTOR=text=Submit App
DBA_INFO_SELECTOR=text=DBA Info
SUBMIT_SELECTOR=input[value="Submit Application"], button:has-text("Submit Application"), text=Submit Application
LOGO_SELECTOR=img

# Website field mapping. Left side is Sheet label, right side is website target.
# Use label=Field Name for text inputs and select-label=Field Name for dropdowns.
FIELD_MAP=Your_Google_Sheet_lable=Your_website_field

# Optional: after submit, extract customer id using this regex from the page text.
# Matches "Customer ID # 1234567890" or "Cust # 1234567890".
CUSTOMER_ID_REGEX='(?:Customer\s*ID\s*#?|Cust\s*#)\s*[:#-]?\s*(\d{10})'
